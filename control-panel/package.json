{
  "name": "solar-control-panel",
  "private": true,
  "version": "1.0.0",
  "description": "Desktop operations panel for the SOLAR quadruped robot.",
  "author": "SOLAR",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "node electron/dev-server.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.solar.controlpanel",
    "productName": "SOLAR Control Panel",
    "directories": {
      "output": "release-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "SOLAR-Control-Panel-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.16"
  }
}
