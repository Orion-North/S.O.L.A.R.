#pragma once

// Copy this file to secrets.h locally and set project-specific values there.
#define SOLAR_HOME_SSID "your-wifi-ssid"
#define SOLAR_HOME_PASSWORD "your-wifi-password"
#define SOLAR_FALLBACK_SSID "SOLAR_AP"
#define SOLAR_FALLBACK_PASSWORD "change-this-ap-password"
#define SOLAR_OTA_USER "solar"
#define SOLAR_OTA_PASSWORD "change-this-ota-password"
// Leave empty to disable command-token checks on the local robot network.
#define SOLAR_API_TOKEN ""

// Optional solar-panel voltage telemetry for /status.
// Use a resistor divider and set the ratio as panel_voltage / adc_voltage.
// Keep the ADC pin input at or below 3.3 V.
// Prefer ADC1-capable pins; ADC2 pins are unreliable while Wi-Fi is active.
#define SOLAR_PANEL_ADC_PIN -1
#define SOLAR_PANEL_VOLTAGE_DIVIDER 2.0f
